server {
  listen 80;
  server_name natone.ru www.natone.ru;

  location /.well-known/acme-challenge/ {
    root /var/www/certbot;
  }

  location / {
    return 301 https://$host$request_uri;
  }
}

server {
  listen 443 ssl http2;
  server_name natone.ru www.natone.ru;
  resolver 127.0.0.11 valid=30s ipv6=off;

  ssl_certificate /etc/letsencrypt/live/natone.ru/fullchain.pem;
  ssl_certificate_key /etc/letsencrypt/live/natone.ru/privkey.pem;

  location /api/ {
    set $backend_upstream backend:3000;
    proxy_pass http://$backend_upstream/;
    proxy_http_version 1.1;
    proxy_connect_timeout 30s;
    proxy_send_timeout 60s;
    proxy_read_timeout 120s;
    send_timeout 120s;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
  }

  location / {
    set $frontend_upstream frontend:3000;
    proxy_pass http://$frontend_upstream;
    proxy_http_version 1.1;
    proxy_connect_timeout 30s;
    proxy_send_timeout 60s;
    proxy_read_timeout 180s;
    send_timeout 180s;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
  }
}
