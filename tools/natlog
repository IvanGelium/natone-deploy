#!/usr/bin/env bash
set -euo pipefail

HOST="leonid@72.56.232.199"
KEY_PATH="$HOME/.ssh/natone_leonid"
ROOT_HOST="root@72.56.232.199"
ROOT_KEY_PATH="$HOME/.ssh/natone_root"
ROOT_DIR="/opt/natone"
DEPLOY_DIR="$ROOT_DIR/natone-deploy"

usage() {
  cat <<'USAGE'
Usage:
  ./natlog                 # SSH into server
  ./natlog --root           # SSH into server as root
  ./natlog --deploy         # start deploy in background and wait for result
  ./natlog --status         # docker compose ps
  ./natlog --logs <service> # tail logs (nginx|backend|frontend|db|certbot)
  ./natlog --fetch-backup [dest] # download latest backup to dest (default .)
  ./natlog --migrate        # run prisma migrate deploy in backend container
  ./natlog --restart        # docker compose restart
  ./natlog --pull           # git pull in all repos (deploy, backend, frontend)
  ./natlog --down           # docker compose down
USAGE
}

ssh_run() {
  local cmd="$1"
  ssh -i "$KEY_PATH" "$HOST" "$cmd"
}

start_deploy_bg() {
  local run_id
  run_id="$(date +%Y%m%d-%H%M%S)"
  local remote_cmd="
set -e
cd '$DEPLOY_DIR'
LOG_FILE='/opt/natone/deploy-${run_id}.log'
STATUS_FILE='/opt/natone/deploy-${run_id}.status'
PID_FILE='/opt/natone/deploy-${run_id}.pid'
nohup bash -lc \"./deploy.sh >\\\"\$LOG_FILE\\\" 2>&1; echo \\\$? >\\\"\$STATUS_FILE\\\"\" >/dev/null 2>&1 &
echo \$! >\"\$PID_FILE\"
echo \"RUN_ID=${run_id}\"
echo \"LOG_FILE=\$LOG_FILE\"
echo \"STATUS_FILE=\$STATUS_FILE\"
echo \"PID_FILE=\$PID_FILE\"
"

  ssh_run "$remote_cmd"
}

wait_deploy_result() {
  local run_id="$1"
  local status_file="/opt/natone/deploy-${run_id}.status"
  local log_file="/opt/natone/deploy-${run_id}.log"

  echo "Ожидаю завершение деплоя RUN_ID=$run_id"
  while true; do
    if result="$(ssh_run "if [ -f '$status_file' ]; then cat '$status_file'; fi" 2>/dev/null)"; then
      if [[ -n "$result" ]]; then
        echo
        echo "=== Последние логи деплоя ==="
        ssh_run "tail -n 120 '$log_file'" || true
        if [[ "$result" == "0" ]]; then
          echo "Деплой завершился успешно."
          return 0
        fi
        echo "Деплой завершился с ошибкой (exit $result)." >&2
        return 1
      fi
      printf "."
    else
      echo
      echo "SSH временно недоступен, продолжаю ждать..."
    fi
    sleep 5
  done
}

case "${1:-}" in
  "")
    echo "Подключаемся к natone $HOST"
    ssh -ti "$KEY_PATH" "$HOST" "cd $ROOT_DIR && exec bash -l"
    ;;
  --root)
    echo "Подключаемся к natone $ROOT_HOST"
    ssh -ti "$ROOT_KEY_PATH" "$ROOT_HOST" "cd $ROOT_DIR && exec bash -l"
    ;;
  --deploy)
    echo "Запускаю деплой на $HOST"
    deploy_info="$(start_deploy_bg)"
    echo "$deploy_info"
    run_id="$(echo "$deploy_info" | awk -F= '/^RUN_ID=/{print $2}')"
    if [[ -z "$run_id" ]]; then
      echo "Не удалось получить RUN_ID деплоя" >&2
      exit 1
    fi
    wait_deploy_result "$run_id"
    ;;
  --status)
    ssh_run "cd $DEPLOY_DIR && docker compose ps"
    ;;
  --logs)
    if [[ -z "${2:-}" ]]; then
      echo "Укажи сервис для логов" >&2
      usage
      exit 1
    fi
    ssh_run "cd $DEPLOY_DIR && docker compose logs --tail=200 $2"
    ;;
  --fetch-backup)
    dest="${2:-.}"
    remote_file="$(ssh -i "$KEY_PATH" "$HOST" "ROOT_DIR=$ROOT_DIR $DEPLOY_DIR/tools/backup.sh --latest")"
    echo "Скачиваю $remote_file -> $dest"
    scp -i "$KEY_PATH" "$HOST:$remote_file" "$dest"
    ;;
  --migrate)
    ssh_run "cd $DEPLOY_DIR && docker compose exec backend npx prisma migrate deploy"
    ;;
  --restart)
    ssh_run "cd $DEPLOY_DIR && docker compose restart"
    ;;
  --pull)
    ssh_run "cd $ROOT_DIR/natone-deploy && git pull --ff-only"
    ssh_run "cd $ROOT_DIR/natone-backend && git pull --ff-only"
    ssh_run "cd $ROOT_DIR/natone-nuxt && git pull --ff-only"
    ;;
  --down)
    ssh_run "cd $DEPLOY_DIR && docker compose down"
    ;;
  -h|--help)
    usage
    ;;
  *)
    echo "Неизвестный флаг: $1" >&2
    usage
    exit 1
    ;;
esac
